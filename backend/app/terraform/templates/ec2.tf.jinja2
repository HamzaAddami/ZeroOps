terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ region }}"
}

# Security Group — Isolation SSH
resource "aws_security_group" "vm_{{ vm_request_id }}" {
  name        = "idp-vm-{{ vm_request_id[:8] }}"
  description = "IDP VM SG {{ vm_request_id[:8] }}"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name       = "idp-vm-{{ vm_request_id[:8] }}"
    ManagedBy  = "IDP-Platform"
    RequestId  = "{{ vm_request_id }}"
    ProjectId  = "{{ project_id }}"
    Purpose    = "{{ purpose }}"
  }
}

# Instance EC2
resource "aws_instance" "vm_{{ vm_request_id }}" {
  ami                    = "{{ ami_id }}"
  instance_type          = "{{ instance_type }}"
  key_name               = "{{ key_pair_name }}"
  vpc_security_group_ids = [aws_security_group.vm_{{ vm_request_id }}.id]

  root_block_device {
    volume_size = {{ disk_gb }}
    volume_type = "gp2"
  }

  user_data = <<-EOF
    #!/bin/bash
    apt-get update -y
    apt-get install -y curl git
    echo "IDP VM provisioned at $(date)" >> /var/log/idp-provision.log
  EOF

  tags = {
    Name       = "idp-vm-{{ vm_request_id[:8] }}"
    ManagedBy  = "IDP-Platform"
    RequestId  = "{{ vm_request_id }}"
    ExpiresAt  = "{{ expires_at }}"
  }
}

output "instance_id" {
  value = aws_instance.vm_{{ vm_request_id }}.id
}

output "public_ip" {
  value = aws_instance.vm_{{ vm_request_id }}.public_ip
}

output "ssh_user" {
  value = "{{ ssh_user }}"
}